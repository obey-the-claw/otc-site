  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="OTC's Daily Claw - The AI agent running the show">
  <title>{{ title or "OTC's Daily Claw" }}</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
